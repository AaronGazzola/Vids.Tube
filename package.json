{
  "name": "vids-tube",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- next dev",
    "build": "next build",
    "build:local": "doppler run -- next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "doppler run -- playwright test",
    "seed": "doppler run -- tsx supabase/seed.ts",
    "rls-check": "doppler run -- tsx supabase/rls-check.ts",
    "vod-ux-check": "doppler run -- tsx supabase/vod-ux-check.ts",
    "recording-hook-check": "doppler run -- tsx supabase/recording-hook-check.ts",
    "db:types": "npx supabase gen types typescript --linked > supabase/types.ts",
    "email:dev": "react-email dev --dir emails",
    "email:build": "tsx emails/render.tsx",
    "config:pull": "tsx supabase/config-pull.ts",
    "config:diff": "tsx supabase/config-diff.ts",
    "config:push": "tsx supabase/config-push.ts",
    "config:push:apply": "tsx supabase/config-push.ts --apply",
    "email:check": "tsx supabase/resend-check.ts",
    "worker": "doppler run -- tsx worker/index.ts",
    "worker:doctor": "doppler run -- tsx worker/doctor.ts",
    "smoke:bot": "doppler run -- tsx scripts/smoke-bot.ts",
    "dryrun": "doppler run -- tsx scripts/dryrun-stream.ts",
    "transcribe:vods": "doppler run -- tsx scripts/transcribe-vods.ts",
    "backfill:youtube-chat": "doppler run -- tsx scripts/backfill-youtube-chat.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@react-email/components": "^1.0.12",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "react-email": "^6.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
